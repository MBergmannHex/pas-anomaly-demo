{
  "name": "alarm-analyzer-pro",
  "version": "5.0.0",
  "description": "AI-Enhanced alarm rationalization for process control systems",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test e2e/app-loads.spec.js e2e/csv-upload.spec.js e2e/dr-wizard.spec.js e2e/settings.spec.js",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.js",
    "test:e2e:update-snapshots": "playwright test e2e/visual-regression.spec.js --update-snapshots"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "docx": "^9.6.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
